                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Button>
                                <Label fx:id="statusBar" alignment="CENTER" layoutX="40.0" layoutY="390.0" prefHeight="60.0" prefWidth="720.0" text="Status weryfikacji">
                                    <font><Font size="20.0" /></font>
